# =============================================
# API DE ANTHROPIC (Claude)
# =============================================
ANTHROPIC_API_KEY=tu_api_key_de_anthropic

# =============================================
# CORS (Orígenes permitidos)
# =============================================
FRONTEND_URL=http://localhost:3000
