# =============================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# BASE DE DATOS POSTGRESQL
# =============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=burnoutcare
DB_USER=tu_usuario
